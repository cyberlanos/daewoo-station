<DefaultWindow xmlns="https://spacestation14.io"
               Title="{Loc 'general-station-record-console-window-title'}"
               MinSize="750 500">
    <BoxContainer Orientation="Vertical">
        <BoxContainer Margin="5 5 5 10" HorizontalExpand="true" VerticalAlignment="Center">
            <OptionButton Name="StationRecordsFilterType" MinWidth="200" Margin="0 0 10 0"/>
            <!-- Pirate: general/security record decoupling (record toolbar start) -->
            <Button Name="DeleteRecordButton"
                    MaxSize="32 32"
                    StyleClasses="OpenBoth"
                    Margin="0 0 4 0"
                    ToolTip="delete">
                <TextureRect StyleClasses="ButtonSquare"
                             TexturePath="/Textures/Interface/VerbIcons/delete_transparent.svg.192dpi.png"
                             Stretch="KeepAspectCentered"
                             MinSize="18 18" />
            </Button>
            <Button Name="AddRecordButton"
                    MaxSize="32 32"
                    StyleClasses="OpenBoth"
                    Margin="0 0 10 0"
                    ToolTip="Add record">
                <TextureRect StyleClasses="ButtonSquare"
                             TexturePath="/Textures/Interface/VerbIcons/plus.svg.192dpi.png"
                             Stretch="KeepAspectCentered"
                             MinSize="18 18" />
            </Button>
            <!-- Pirate: general/security record decoupling (record toolbar end) -->
            <LineEdit Name="StationRecordsFiltersValue"
                PlaceHolder="{Loc 'general-station-record-for-filter-line-placeholder'}" HorizontalExpand="True"/>
        </BoxContainer>
        <BoxContainer VerticalExpand="True">
            <!-- Record listing -->
            <BoxContainer Orientation="Vertical" Margin="5" MinWidth="250" MaxWidth="250">
                <Label Name="RecordListingStatus" Visible="False" />
                <ScrollContainer VerticalExpand="True">
                    <ItemList Name="RecordListing" />
                </ScrollContainer>
            </BoxContainer>
            <!-- Pirate: general/security record layout alignment -->
            <BoxContainer Orientation="Vertical" Margin="5" HorizontalExpand="True">
                <Label Name="RecordContainerStatus" Visible="False" Text="{Loc 'general-station-record-console-select-record-info'}"/>
                <Control Name="RecordContainer" Visible="False" HorizontalExpand="True"/>
            </BoxContainer>
        </BoxContainer>
    </BoxContainer>
</DefaultWindow>
